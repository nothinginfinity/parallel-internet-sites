{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Client Intake — Parallel Internet Site",
  "description": "Complete this schema for each client before generating a Parallel Internet Site.",
  "type": "object",
  "required": ["business_name", "main_website_url", "business_description", "services", "primary_cta", "cta_url", "contact_email"],
  "properties": {
    "business_name":           { "type": "string", "description": "Legal or brand name of the business" },
    "main_website_url":        { "type": "string", "format": "uri", "description": "Primary human-facing website URL" },
    "parallel_site_url":       { "type": "string", "format": "uri", "description": "URL where the Parallel Internet Site will be deployed" },
    "business_type":           { "type": "string", "description": "e.g. LLC, Sole Proprietor, Corporation, Nonprofit" },
    "business_description":    { "type": "string", "description": "1–3 sentence plain-language description of what the business does" },
    "target_audience":         { "type": "string", "description": "Who the business serves" },
    "services":                { "type": "array", "items": { "type": "string" }, "description": "List of services offered" },
    "primary_cta":             { "type": "string", "description": "Label for the primary call to action, e.g. 'Get Started' or 'Book a Call'" },
    "cta_url":                 { "type": "string", "format": "uri", "description": "URL for the primary CTA" },
    "contact_name":            { "type": "string", "description": "Primary contact person name" },
    "contact_email":           { "type": "string", "format": "email" },
    "phone":                   { "type": "string" },
    "service_area":            { "type": "string", "description": "Geographic service area or 'Nationwide' / 'Remote'" },
    "business_hours":          { "type": "string", "description": "e.g. Mon–Fri 9am–5pm PT" },
    "founding_year":           { "type": "string" },
    "clients_served":          { "type": "string", "description": "e.g. '500+' or 'small businesses in the US'" },
    "positioning_statement":   { "type": "string", "description": "One-sentence differentiator" },
    "industry_category":       { "type": "string" },
    "content_policy_notes":    { "type": "string" },
    "compliance_disclaimers":  { "type": "array", "items": { "type": "string" } },
    "do_not_claim":            { "type": "array", "items": { "type": "string" }, "description": "Claims that must never appear on the site" },
    "source_of_truth_pages":   { "type": "array", "items": { "type": "string", "format": "uri" }, "description": "Approved URLs that can be cited as sources" },
    "faq_topics":              { "type": "array", "items": { "type": "string" } },
    "comparison_topics":       { "type": "array", "items": { "type": "string" } },
    "agent_priority_prompts":  { "type": "array", "items": { "type": "string" }, "description": "Exact prompts this site is designed to answer" },
    "competitors_or_alternatives": { "type": "array", "items": { "type": "string" } },
    "brand_voice":             { "type": "string", "description": "e.g. 'Professional and direct', 'Friendly and approachable'" },
    "social_links":            { "type": "object", "additionalProperties": { "type": "string" } },
    "has_rss":                 { "type": "boolean" }
  }
}
